# =============================================================
# Frontend — Required Environment Variables
# =============================================================
# For local development: copy this file to .env and fill in values.
# For production (Vercel/Netlify): set these in the dashboard.
#
# REACT_APP_* variables are embedded at build time.
# =============================================================

# URL of the backend API server
# Local development:  http://localhost:8080
# Production:         https://your-backend.onrender.com
REACT_APP_API_URL=http://localhost:8080
