# ============================================================
# TradeLearn E2E — .gitignore
# ============================================================
# Playwright generates all of the following at runtime.
# Never commit these to the repository.
# ============================================================

# ── Playwright output ──────────────────────────────────────
test-results/
playwright-report/
playwright-prod-report/

# ── Production test run artifacts ─────────────────────────
prod-test-results/
prod-test-results-*/
prod-test-results.json
prod-test-accounts.log

# ── Trace snapshots (generated by --trace on-failure) ─────
trace_inspect/
trace_inspect_first/
trace_out/
trace_out*/

# ── Node modules ──────────────────────────────────────────
node_modules/
