# ============================================================
# TradeLearn — Root .gitignore
# ============================================================

# ── Local dev config (contains real credentials) ──────────
backend/src/main/resources/application-local.properties

# ── Environment files ──────────────────────────────────────
.env
*.env
!.env.example

# ── Node ──────────────────────────────────────────────────
node_modules/

# ── Maven build output ─────────────────────────────────────
backend/target/
**/target/

# ── React production build ─────────────────────────────────
frontend/build/

# ── Log files ──────────────────────────────────────────────
*.log
backend/logs/

# ── IDE and Editor ─────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Accidentally committed personal files ─────────────────
backend/settings.json
backend/errors.txt

# ── Key material ──────────────────────────────────────────
*.pem
*.p12
*.jks
*.keystore

# ── Archives / temp ───────────────────────────────────────
*.zip
*.tar.gz
*.tmp

# ── Generated reports / dumps ─────────────────────────────
project_structure.txt
code_verification.txt

# ── Playwright E2E test output artifacts ──────────────────
# These are generated at runtime and must never be committed.
e2e/test-results/
e2e/playwright-report/
e2e/playwright-prod-report/
e2e/prod-test-results/
e2e/prod-test-results-*/
e2e/trace_inspect/
e2e/trace_inspect_first/
e2e/trace_out/
e2e/trace_out*/
e2e/prod-test-accounts.log
e2e/prod-test-results.json

# ── Root-level debug / scratch scripts ────────────────────
scratch-*.js

internal-notes/
