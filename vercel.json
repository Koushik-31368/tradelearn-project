{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tradelearn-project-g.onrender.com/api/:path*"
    },
    { "source": "/((?!static/|.*\\.).*)", "destination": "/index.html" }
  ]
}
