# =============================================================
# Backend — Required Environment Variables
# =============================================================
# Copy this file's key=value pairs to your deployment platform
# (e.g., Render → Environment → Add Environment Variable).
#
# For local development: create application-local.properties
# (already gitignored). Do NOT store real secrets here.
# =============================================================

# Spring profile to activate ('local' or 'prod')
SPRING_PROFILES_ACTIVE=prod

# Server port (Render sets PORT automatically — do NOT add this manually on Render)
PORT=8080

# ── PostgreSQL / Neon (Production) ───────────────────────────
# Full JDBC URL from your PostgreSQL provider.
# Neon REQUIRES sslmode=require — include it in the URL.
DATABASE_URL=jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
DATABASE_USERNAME=<your_db_username>
DATABASE_PASSWORD=<your_db_password>

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 64 random characters (512 bits).
# Generate with: openssl rand -hex 64
JWT_SECRET=<minimum_64_character_random_secret_key_here>
JWT_EXPIRATION_MS=86400000

# ── Redis ─────────────────────────────────────────────────────
# Redis is OPTIONAL. Set REDIS_ENABLED=true to activate:
#   - Distributed matchmaking queue
#   - Distributed locks (Redisson)
#   - Multi-instance WebSocket relay (Pub/Sub)
#
# When REDIS_ENABLED is false or absent, the app starts without Redis.
# Multiplayer matchmaking and rematch will be unavailable.
#
# If using Upstash on Render, use the Redis host and port from the
# Upstash dashboard (NOT the redis:// URL).
REDIS_ENABLED=false
REDIS_HOST=<your_redis_host>
REDIS_PORT=6379

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

