# ============================================================
# TradeLearn Backend — Environment Variables
# ============================================================
# Copy this file to .env (or set these as system env vars)
# for local development. Production values are set in Render.
# ============================================================

# Spring profile to activate
SPRING_PROFILES_ACTIVE=local

# Server port
PORT=8080

# Database (for local / prod)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/tradelearn
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# Redis (optional — set redis.enabled=true to use)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT secret (must be at least 256 bits for HS256)
JWT_SECRET=your-very-long-random-secret-here

# Optional: instance ID for multi-server debugging
INSTANCE_ID=local-1
