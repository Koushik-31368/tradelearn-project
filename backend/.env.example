# ============================================================
# TradeLearn Backend — Environment Variables
# ============================================================
# Copy this file to .env (or set these as system env vars)
# for local development. Production values are set in Render.
# ============================================================

# Spring profile to activate
SPRING_PROFILES_ACTIVE=local

# Server port
PORT=8080

# Database (for local / prod)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/tradelearn
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# Redis (optional — set redis.enabled=true to use)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT secret (must be at least 256 bits for HS256)
JWT_SECRET=your-very-long-random-secret-here

# JWT refresh token secret — MUST be different from JWT_SECRET.
# If omitted, a derived fallback is used (not recommended for production).
JWT_REFRESH_SECRET=your-separate-refresh-token-secret-at-least-32-chars

# Access token TTL in ms (default 900000 = 15 min in prod)
JWT_EXPIRATION_MS=900000

# Refresh token TTL in ms (default 604800000 = 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000

# Cookie settings for the httpOnly refresh token
# COOKIE_SECURE=true   — required when using HTTPS (always true in prod)
# COOKIE_SAME_SITE     — "None" for cross-domain (Vercel→Render), "Lax" for same-domain
COOKIE_SECURE=true
COOKIE_SAME_SITE=None

# Optional: instance ID for multi-server debugging
INSTANCE_ID=local-1
